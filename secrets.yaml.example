# Copy this file to secrets.yaml and fill in your values
# The secrets.yaml file is gitignored for security

# WiFi Configuration
wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# API Configuration
# Generate at https://esphome.io/components/api/#api-key
api_encryption_key: "your-base64-encryption-key-here"

# OTA Configuration
# Generate at https://bitwarden.com/password-generator/
ota_password: "your-ota-password-here"

# Optional: Syslog Server (if using syslog feature)
syslog_server: "X.X.X.X"

# Optional: Captive Portal password (if using syslog feature)
captive_portal_password: "<secure_password>"

